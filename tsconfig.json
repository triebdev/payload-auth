{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "rootDir": "./",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "target": "ES2022",
    "noEmit": true,
    "paths": {
      "@payload-config": ["./dev/payload.config.ts"],
      "@trieb.work/payload-auth": ["./src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./src/**/*.d.ts",
    "./dev/**/*.ts",
    "./dev/**/*.tsx",
    "./dev/**/*.js",
    "./dev/**/*.jsx",
    "./dev/**/*.mjs",
    "./tests/**/*.ts",
    "./dev/next-env.d.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
